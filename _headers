/.well-known/apple-app-site-association
  Content-Type: application/json

/app/next/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self'; img-src 'self' data: blob: https://ebccwnkmsnhbljxxxdej.supabase.co; connect-src 'self' https://ebccwnkmsnhbljxxxdej.supabase.co wss://ebccwnkmsnhbljxxxdej.supabase.co; form-action 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), payment=(), geolocation=(self)

# Revalidate all static assets so a new deploy never serves stale CSS/JS
# against fresh HTML (the two-browser mismatch). no-cache = browser still
# caches but must revalidate via etag → cheap 304 when unchanged.
/*.css
  Cache-Control: no-cache

/*.js
  Cache-Control: no-cache

/*.html
  Cache-Control: no-cache
